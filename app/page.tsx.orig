                <div className="absolute top-[10%] left-[-10%] z-20 hidden lg:block">
                  <h3 className="font-headline text-[clamp(2.5rem,4vw,3.5rem)] leading-[1.05] text-[#4C433C] whitespace-nowrap drop-shadow-sm">
