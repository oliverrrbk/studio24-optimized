                </div>

                {/* Sticker Badge Overlaid Bottom Left (Decorative Scalloped Dashed Oval) */}
                <div className="absolute bottom-[-8%] left-[2%] md:bottom-[-2%] md:left-[12%] z-30 w-[clamp(7.5rem,15vw,11.5rem)] h-[clamp(9rem,18vw,14rem)] flex items-center justify-center translate-y-3">
                  <svg viewBox="0 0 100 120" className="w-full h-full text-[#7A6F68] drop-shadow-sm overflow-visible">
                    <path
                      d="M 85.00 60.00 Q 90.90 77.92 78.32 89.39 Q 75.27 106.92 60.82 107.55 Q 50.00 118.00 39.18 107.55 Q 24.73 106.92 21.68 89.39 Q 9.10 77.92 15.00 60.00 Q 9.10 42.08 21.68 30.61 Q 24.73 13.08 39.18 12.45 Q 50.00 2.00 60.82 12.45 Q 75.27 13.08 78.32 30.61 Q 90.90 42.08 85.00 60.00"
                      fill="none"
